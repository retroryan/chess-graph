# Neo4j Aura connection
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password-here

# Data source paths — use full absolute paths or relative to this directory
#
# OPENINGS_TSV: The c.tsv file from the Lichess chess-openings repo.
#   Contains ECO codes, opening names, and PGN move sequences.
#   Clone from: https://github.com/lichess-org/chess-openings
#
# PUZZLES_DIR: The bundled puzzle JSON files from the chess-coach-ai app.
#   Each subfolder is a tactical theme (fork, pin, etc.) with 4 difficulty
#   bands (beginner.json through expert.json). Part of this project at
#   chess-coach-ai/src/data/puzzles/
#
OPENINGS_TSV=../../chess-openings/c.tsv
PUZZLES_DIR=../../chess-coach-ai/src/data/puzzles

# GAMES_NDJSON: NDJSON file of Lichess games downloaded by the
#   lichess_api_downloader tool. Each line is a JSON object with game
#   metadata and SAN moves. See chess-graph/lichess_api_downloader/
#
GAMES_NDJSON=../lichess_api_downloader/output/italian_game_games.ndjson
