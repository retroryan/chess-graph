# Lichess API Downloader Configuration
# Copy to .env and adjust as needed

# Number of games to download
GAME_COUNT=500

# Player rating range
# Run `uv run lichess-downloader probe` to see game counts per bracket
# Lichess uses rating buckets: 0, 1000, 1200, 1400, 1600, 1800, 2000, 2200, 2500+
# Example ranges:
#   Beginner:       RATING_MIN=0    RATING_MAX=1200
#   Improving:      RATING_MIN=1200 RATING_MAX=2000
#   Advanced:       RATING_MIN=1800 RATING_MAX=2500
#   All:            RATING_MIN=0    RATING_MAX=3000
RATING_MIN=1200
RATING_MAX=2000

# Rate limits (requests per second)
# General Lichess API: ~20/s unauthenticated, higher with API token
RATE_LIMIT=20
# Opening Explorer API runs on a separate server with stricter limits
EXPLORER_RATE_LIMIT=2

# Output directory for downloaded NDJSON files
OUTPUT_DIR=output

# Optional: Lichess API Personal Access Token
# Enables the Opening Explorer probe command and explorer-based game collection
# Get a free token at: https://lichess.org/account/oauth/token
# Without a token, the downloader uses the HuggingFace puzzle dataset instead
# LICHESS_TOKEN=lip_xxxxxxxxxxxxxxxxxxxxxxxx
